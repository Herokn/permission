{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "types": ["vite/client", "vue", "vue/jsx"],
    "skipLibCheck": true,
    "paths": { "@/*": ["src/*"] }
  },
  "include": ["src", "env.d.ts"],
  "exclude": ["dist", "node_modules"]
}
