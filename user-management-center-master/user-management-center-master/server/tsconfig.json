{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "es2020",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "baseUrl": "./",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
