# Permission Center 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ===========================================
# 必填配置
# ===========================================

# JWT 密钥（至少 32 字符，生产必须替换为随机串；勿使用文档模板中的示例值）
# 生成方式: openssl rand -base64 32
# 必填（至少 32 字符）。勿使用曾出现在默认配置中的固定串。
JWT_SECRET=replace-with-openssl-rand-base64-at-least-32-chars

# 本地 IDE 无上面变量时：可激活 dev 配置
# SPRING_PROFILES_ACTIVE=dev

# 数据库密码
DB_PASSWORD=your-database-password

# 超级管理员 JWT 业务 userId（逗号分隔）。默认含 sys_admin 与 admin，兼容旧 Token；仅设 sys_admin 可收紧
# PERMISSION_SUPER_ADMINS=sys_admin,admin

# ===========================================
# 可选配置
# ===========================================

# 管理员用户密码（不设置则无法使用admin账号登录）
AUTH_ADMIN_PASS=admin123

# 普通用户密码
AUTH_USER1_PASS=user123

# 数据库用户名（默认root）
DB_USERNAME=root

# ===========================================
# Docker Compose 专用
# ===========================================

# 以下变量由 docker-compose 自动读取
# 无需手动设置
