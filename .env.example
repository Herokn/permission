# Permission Center 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ===========================================
# 必填配置
# ===========================================

# JWT 密钥（至少32字符，生产环境必须修改）
# 生成方式: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# 数据库密码
DB_PASSWORD=your-database-password

# ===========================================
# 可选配置
# ===========================================

# 管理员用户密码（不设置则无法使用admin账号登录）
AUTH_ADMIN_PASS=

# 普通用户密码
AUTH_USER1_PASS=

# 数据库用户名（默认root）
DB_USERNAME=root

# ===========================================
# Docker Compose 专用
# ===========================================

# 以下变量由 docker-compose 自动读取
# 无需手动设置
