PORT=4130
USE_PROXY=1
FE_DEV_PORT=3050
ENABLE_CORS=0
FE_BASE_PREFIX=/mf-shell
FE_REWRITE_PREFIX=/mf-shell

# SSO 配置模板
# 复制此文件为 .env.development、.env.test、.env.production 并填写实际值

SSO_BASE_URL=https://gw.lvshiwanyang.com/wb-sso
SSO_CLIENT_ID=your-client-id
SSO_CLIENT_SECRET=your-client-secret
SSO_REDIRECT_URI=your-redirect-uri
